# GT7 Tool 設定テンプレート (.env)
# このファイルをコピーして .env を作成し、実際の値を設定してください:
#   cp .env.example .env
# .env は .gitignore で除外されコミットされません。
# ここで未設定の項目は config.json の値が使われます(後方互換)。
# ※ docker compose はプロジェクト直下の .env を自動読込し、docker-compose.yml の
#   `${PS5_IP:-...}` 形式の変数展開に使います(.env の値が既定値を上書き)。
#   直接 `python main.py` で起動する場合は .env は自動では読まれません —
#   シェルで export するか、config.json を編集してください。

# PS5 / PS4 の IP アドレス(必須)
PS5_IP=192.168.x.x

# GT7 テレメトリ ポート(通常は変更不要)
SEND_PORT=33739
RECEIVE_PORT=33740

# ダッシュボードの HTTP/WebSocket ポート
HTTP_PORT=8080

# ハートビート送信間隔(秒)
HEARTBEAT_INTERVAL=10
