# GT7 Tool 設定テンプレート (.env)
# このファイルをコピーして .env を作成し、実際の値を設定してください:
#   cp .env.example .env
# .env は .gitignore で除外されコミットされません。
# ここで未設定の項目は config.json の値が使われます(後方互換)。
# ※ docker compose は docker-compose.yml の environment 値を優先します。
#   直接 `python main.py` 実行時や、compose の environment を外した場合に .env が効きます。

# PS5 / PS4 の IP アドレス(必須)
PS5_IP=192.168.x.x

# GT7 テレメトリ ポート(通常は変更不要)
SEND_PORT=33739
RECEIVE_PORT=33740

# ダッシュボードの HTTP/WebSocket ポート
HTTP_PORT=8080

# ハートビート送信間隔(秒)
HEARTBEAT_INTERVAL=10
